# CatsCompany Environment Configuration
# Copy this file to deploy/.env and fill in your values

# ============================================
# Database Configuration
# ============================================
OC_DB_DRIVER=mysql
# MySQL DSN is normally assembled by Docker Compose from the values below.
# For PostgreSQL deployments, set OC_DB_DRIVER=postgres and provide a URL DSN.
# OC_DB_DSN=postgres://catsco:replace-with-password@postgres.internal:5432/catsco?sslmode=prefer
OC_DB_MAX_OPEN_CONNS=25
OC_DB_MAX_IDLE_CONNS=10
OC_DB_CONN_MAX_LIFETIME=30m
OC_DB_CONN_MAX_IDLE_TIME=5m
# Optional shared runtime for multi-instance bot body leases and Device RPC routing.
# Leave empty for single-instance process-local mode.
OC_RUNTIME_STORE=
OC_REDIS_URL=
OC_REDIS_KEY_PREFIX=catsco:dev
CATSCO_NODE_ID=

MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_USER=openchat
MYSQL_PASSWORD=your-secure-db-password

# ============================================
# Bot Credentials
# ============================================
# Password for the default AI assistant bot
BOT_ASSISTANT_PASSWORD=your-secure-bot-password

# API key for Xiaoba bot (if using)
XIAOBA_BOT_API_KEY=

# ============================================
# LLM API Configuration
# ============================================
# OpenAI-compatible API endpoint
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-3.5-turbo

# Alternative: DeepSeek
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Alternative: Qwen (通义千问)
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# ============================================
# Security (Production)
# ============================================
# JWT secret for token signing
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ============================================
# Email Verification (Tencent Cloud SES)
# ============================================
TENCENTCLOUD_SECRET_ID=your-tencent-cloud-secret-id
TENCENTCLOUD_SECRET_KEY=your-tencent-cloud-secret-key
TENCENTCLOUD_REGION=ap-guangzhou
TENCENT_SES_FROM_EMAIL=noreply@mail.catsco.cc
TENCENT_SES_FROM_NAME=Cats Company
TENCENT_SES_TEMPLATE_ID=174748
TENCENT_SES_SUBJECT=Cats Company 注册验证码
# Optional. Defaults to TENCENT_SES_FROM_EMAIL when empty.
TENCENT_SES_REPLY_TO=

# ============================================
# Optional: User Feedback Notifications
# ============================================
# Reuse the same Feishu bot webhook as daily ops monitor if desired.
FEISHU_WEBHOOK_URL=
FEISHU_KEYWORD=cats-company
# Optional override if feedback should be sent to a separate Feishu bot.
FEEDBACK_FEISHU_WEBHOOK_URL=
FEEDBACK_FEISHU_KEYWORD=
# Optional. Used to turn /uploads/feedback/... into a full URL in Feishu.
# Defaults to the current browser page origin when available.
FEEDBACK_PUBLIC_BASE_URL=https://app.catsco.cc

# ============================================
# Optional: Device Connector Releases
# ============================================
CATSCO_DEVICE_CONNECTOR_VERSION=
CATSCO_DEVICE_CONNECTOR_RELEASE_BASE_URL=

# ============================================
# Optional: Feishu Cloud Channel
# ============================================
# Enterprise self-built Feishu app used by CatsCo cloud.
CATSCO_PUBLIC_BASE_URL=https://app.catsco.cc
CATSCO_PUBLIC_WS_URL=wss://app.catsco.cc/v0/channels
CATSCO_FEISHU_APP_ID=
CATSCO_FEISHU_APP_SECRET=
# Required for Dashboard Feishu QR readiness. This must be a real Feishu
# native app/bot entry URL, and it must carry the CatsCo scene back through
# {landing_url_encoded}, {oauth_url_encoded}, or {scene_key}.
# Supports {scene_key}, {scene_key_encoded}, {app_id}, {app_id_encoded},
# {landing_url}, {landing_url_encoded}, {oauth_url}, {oauth_url_encoded},
# {entry_url}, {entry_url_encoded}.
CATSCO_FEISHU_ENTRY_URL_TEMPLATE=
# Must be configured in Feishu Open Platform -> Security Settings -> Redirect URL.
CATSCO_FEISHU_OAUTH_REDIRECT_URI=https://app.catsco.cc/api/channel-agent-bindings/oauth/feishu/callback
# Must be configured in Feishu Open Platform -> Events & Callbacks -> Request URL.
# Request URL: https://app.catsco.cc/api/channels/feishu/events
# Keep event encryption disabled for now; this endpoint accepts plaintext events.
CATSCO_FEISHU_EVENT_VERIFICATION_TOKEN=
# Optional; defaults to app secret when empty.
CATSCO_FEISHU_OAUTH_STATE_SECRET=
# Required in production if external channel adapters call /api/channel-agent-bindings/resolve.
CATSCO_CHANNEL_BINDING_TOKEN=

# ============================================
# Optional: Weixin Official Account Channel
# ============================================
# Official Account app used by CatsCo cloud. Dashboard Weixin entry codes use
# this app to generate parameter QR codes with scene_key.
# CATSCO_PUBLIC_BASE_URL must be the public HTTPS origin for this deployment.
CATSCO_WEIXIN_APP_ID=
CATSCO_WEIXIN_APP_SECRET=
# Must match Weixin Official Accounts Platform -> Basic Configuration -> Server Configuration.
# URL: https://app.catsco.cc/api/channels/weixin/events
# Token: same value as CATSCO_WEIXIN_EVENT_TOKEN
# Message encryption: plaintext or compatible plaintext mode. AES-only mode is not enabled yet.
# If QR image generation fails, check AppSecret, API permissions, and the Weixin IP allowlist.
CATSCO_WEIXIN_EVENT_TOKEN=
# Optional. Defaults to the official Weixin API and QR display endpoints.
CATSCO_WEIXIN_API_BASE_URL=
CATSCO_WEIXIN_QR_SHOW_BASE_URL=

# Optional: Weixin ClawBot channel. This is separate from the official-account
# channel above and uses the Weixin iLink bot authorization QR API.
# Defaults: CATSCO_WEIXIN_CLAWBOT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
# and CATSCO_WEIXIN_CLAWBOT_BOT_TYPE=3.
CATSCO_WEIXIN_CLAWBOT_ILINK_BASE_URL=
CATSCO_WEIXIN_CLAWBOT_BOT_TYPE=
CATSCO_WEIXIN_CLAWBOT_QR_TIMEOUT_SECONDS=
CATSCO_WEIXIN_CLAWBOT_WORKER_ENABLED=
CATSCO_WEIXIN_CLAWBOT_WORKER_REFRESH_SECONDS=
CATSCO_WEIXIN_CLAWBOT_LONGPOLL_SECONDS=
# Optional: comma-separated media download hosts when iLink returns absolute CDN URLs.
# Relative URLs and the configured iLink base host are allowed by default.
CATSCO_WEIXIN_CLAWBOT_MEDIA_HOST_ALLOWLIST=
# Optional: media-id download URL template if getupdates returns only file_id/media_id.
# Supports {media_id}, {resource_id}, {resource_key}, and {file_id}.
CATSCO_WEIXIN_CLAWBOT_MEDIA_DOWNLOAD_URL_TEMPLATE=

# ============================================
# Optional: Bot Deploy Integration
# ============================================
# Gauz Platform deploy API base URL.
# Example (same host, different Docker Compose project):
# DEPLOY_API_URL=http://host.docker.internal:8000
DEPLOY_API_URL=

# ============================================
# Advanced Reader Proxy
# ============================================
# Internal advanced-reader base URL used by Cats backend only.
# Example: http://127.0.0.1:28110
ADVANCED_READER_INTERNAL_URL=

# Optional service-to-service request signing when advanced-reader auth is enabled.
ADVANCED_READER_CLIENT_ID=
ADVANCED_READER_CLIENT_SECRET=
# ADVANCED_READER_CLIENT_SECRET_FILE=/run/secrets/advanced_reader_client_secret

# Optional overrides.
ADVANCED_READER_SIGNING_PATH=/analyze
ADVANCED_READER_INTERNAL_TIMEOUT_SECONDS=300
ADVANCED_READER_PROXY_MAX_BODY_BYTES=104857600

# Go module proxy for Docker builds.
# If your cloud server cannot reach proxy.golang.org, use:
# GOPROXY=https://goproxy.cn,direct
GOPROXY=https://proxy.golang.org,direct

# ============================================
# Optional: SSL/TLS Certificates
# ============================================
# Place your certificates in deploy/nginx/ssl/
# SSL_CERT=fullchain.pem
# SSL_KEY=privkey.pem
