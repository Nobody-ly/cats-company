COMPOSE_PROJECT_NAME=catscompany_test
COMPOSE_PROFILES=mysql
TEST_STACK_ROOT=/srv/catscompany-test
GHCR_REGISTRY=ghcr.io
GHCR_OWNER=replace-with-github-owner
IMAGE_TAG=replace-with-a-commit-sha

TEST_MYSQL_BIND_HOST=127.0.0.1
TEST_MYSQL_HOST_PORT=13306
TEST_API_BIND_HOST=127.0.0.1
TEST_API_HOST_PORT=16061
TEST_GRPC_BIND_HOST=127.0.0.1
TEST_GRPC_HOST_PORT=16062
TEST_WEB_BIND_HOST=127.0.0.1
TEST_WEB_HOST_PORT=18080

MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_USER=openchat
MYSQL_PASSWORD=replace-with-a-strong-db-password
BOT_ASSISTANT_PASSWORD=replace-with-a-bot-password
OC_DB_DRIVER=mysql
OC_DB_DSN=openchat:replace-with-a-strong-db-password@tcp(mysql:3306)/openchat?parseTime=true&charset=utf8mb4
# Tencent Cloud PostgreSQL example:
# OC_DB_DRIVER=postgres
# OC_DB_DSN=postgres://catsco:replace-with-password@postgres.internal:5432/catsco?sslmode=prefer
OC_DB_MAX_OPEN_CONNS=15
OC_DB_MAX_IDLE_CONNS=5
OC_DB_CONN_MAX_LIFETIME=30m
OC_DB_CONN_MAX_IDLE_TIME=5m
# Optional shared runtime for multi-instance bot body leases and Device RPC routing.
# Leave empty for single-instance process-local mode.
OC_RUNTIME_STORE=
OC_REDIS_URL=
OC_REDIS_KEY_PREFIX=catsco:test
CATSCO_NODE_ID=
OC_JWT_SECRET=replace-with-a-random-jwt-secret-at-least-64-chars
# Optional. Enables service-to-service account center APIs.
OC_ACCOUNT_SERVICE_TOKENS=

# Tencent Cloud SES email verification.
TENCENTCLOUD_SECRET_ID=replace-with-tencent-secret-id
TENCENTCLOUD_SECRET_KEY=replace-with-tencent-secret-key
TENCENTCLOUD_REGION=ap-guangzhou
TENCENT_SES_FROM_EMAIL=noreply@mail.catsco.cc
TENCENT_SES_FROM_NAME=Cats Company
TENCENT_SES_TEMPLATE_ID=174748
TENCENT_SES_SUBJECT=Cats Company 注册验证码
# Optional. Defaults to TENCENT_SES_FROM_EMAIL when empty.
TENCENT_SES_REPLY_TO=

# Optional. Reuse the ops monitor Feishu bot for user feedback notifications.
FEISHU_WEBHOOK_URL=
FEISHU_KEYWORD=cats-company
# Optional override if feedback should use a separate Feishu bot.
FEEDBACK_FEISHU_WEBHOOK_URL=
FEEDBACK_FEISHU_KEYWORD=
# Optional. Used to turn /uploads/feedback/... into a full URL in Feishu.
FEEDBACK_PUBLIC_BASE_URL=https://app.catsco.cc

# Optional. Device Connector release metadata shown in the web pairing dialog.
CATSCO_DEVICE_CONNECTOR_VERSION=
CATSCO_DEVICE_CONNECTOR_RELEASE_BASE_URL=

# CatsCo cloud Feishu channel for test deployments.
CATSCO_PUBLIC_BASE_URL=https://app.catsco.cc
CATSCO_PUBLIC_WS_URL=wss://app.catsco.cc/v0/channels
CATSCO_FEISHU_APP_ID=
CATSCO_FEISHU_APP_SECRET=
# Required for Dashboard Feishu QR readiness. This must be a real Feishu
# native app/bot entry URL, and it must carry the CatsCo scene back through
# {landing_url_encoded}, {oauth_url_encoded}, or {scene_key}.
# Supports {scene_key}, {scene_key_encoded}, {app_id}, {app_id_encoded},
# {landing_url}, {landing_url_encoded}, {oauth_url}, {oauth_url_encoded},
# {entry_url}, {entry_url_encoded}.
CATSCO_FEISHU_ENTRY_URL_TEMPLATE=
CATSCO_FEISHU_OAUTH_REDIRECT_URI=https://app.catsco.cc/api/channel-agent-bindings/oauth/feishu/callback
# Feishu Events & Callbacks Request URL:
# https://app.catsco.cc/api/channels/feishu/events
# Keep event encryption disabled for now; this endpoint accepts plaintext events.
CATSCO_FEISHU_EVENT_VERIFICATION_TOKEN=
CATSCO_FEISHU_OAUTH_STATE_SECRET=
# Required in production-like tests if external adapters call /api/channel-agent-bindings/resolve.
CATSCO_CHANNEL_BINDING_TOKEN=

# CatsCo cloud Weixin official-account channel for test deployments.
# CATSCO_PUBLIC_BASE_URL must be this test deployment public HTTPS origin.
CATSCO_WEIXIN_APP_ID=
CATSCO_WEIXIN_APP_SECRET=
# Weixin Official Accounts Platform Server URL:
# https://app.catsco.cc/api/channels/weixin/events
# Token: same value as CATSCO_WEIXIN_EVENT_TOKEN
# Message encryption: plaintext or compatible plaintext mode. AES-only mode is not enabled yet.
# If QR image generation fails, check AppSecret, API permissions, and the Weixin IP allowlist.
CATSCO_WEIXIN_EVENT_TOKEN=
# Optional. Defaults to the official Weixin API and QR display endpoints.
CATSCO_WEIXIN_API_BASE_URL=
CATSCO_WEIXIN_QR_SHOW_BASE_URL=

# Optional. Separate Weixin ClawBot iLink authorization QR settings.
# Defaults: CATSCO_WEIXIN_CLAWBOT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
# CATSCO_WEIXIN_CLAWBOT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
# and CATSCO_WEIXIN_CLAWBOT_BOT_TYPE=3.
CATSCO_WEIXIN_CLAWBOT_ILINK_BASE_URL=
CATSCO_WEIXIN_CLAWBOT_CDN_BASE_URL=
CATSCO_WEIXIN_CLAWBOT_BOT_TYPE=
CATSCO_WEIXIN_CLAWBOT_QR_TIMEOUT_SECONDS=
CATSCO_WEIXIN_CLAWBOT_WORKER_ENABLED=
CATSCO_WEIXIN_CLAWBOT_WORKER_REFRESH_SECONDS=
CATSCO_WEIXIN_CLAWBOT_LONGPOLL_SECONDS=
# Optional: comma-separated media download hosts when iLink returns absolute CDN URLs.
# The observed Weixin ClawBot file host is novac2c.cdn.weixin.qq.com.
CATSCO_WEIXIN_CLAWBOT_MEDIA_HOST_ALLOWLIST=
# Optional: media-id download URL template if getupdates returns only file_id/media_id.
CATSCO_WEIXIN_CLAWBOT_MEDIA_DOWNLOAD_URL_TEMPLATE=

# Optional. Enables relay key creation and one-time relay login tickets.
CATS_RELAY_ADMIN_URL=http://host.docker.internal:18090
CATS_RELAY_ADMIN_TOKEN=
CATS_RELAY_ADMIN_TIMEOUT_SECONDS=15
CATS_RELAY_PUBLIC_BASE_URL=https://relay.catsco.cc
CATS_RELAY_OPENAI_BASE_URL=https://relay.catsco.cc/v1
CATS_RELAY_ANTHROPIC_BASE_URL=https://relay.catsco.cc/anthropic
CATS_RELAY_DEFAULT_MODEL=MiniMax-M2.7
CATS_RELAY_DOCS_URL=https://relay.catsco.cc
CATS_RELAY_SSO_SECRET=

# Optional. Relay commercial package rollout.
# Keep public disabled during rollout; list internal user ids in CATS_RELAY_COMMERCIAL_TEST_UIDS.
# Keep enforce disabled until admin dry-run confirms relay limits can be safely synced.
CATS_RELAY_COMMERCIAL_ENABLED=0
CATS_RELAY_COMMERCIAL_TEST_UIDS=
CATS_RELAY_COMMERCIAL_ENFORCE_ENABLED=0
CATS_RELAY_COMMERCIAL_ENFORCE_UIDS=
